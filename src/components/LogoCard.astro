---
interface Props {
  name: string;
  subtitle: string;
  description: string;
  logoColor?: string;
  logoGradient?: string;
  logoText?: string;
  logoCase?: 'upper' | 'lower';
  logoFont?: 'sans' | 'mono';
  href?: string;
  hrefLabel?: string;
}

const {
  name,
  subtitle,
  description,
  logoColor = '#444',
  logoGradient,
  logoText,
  logoCase = 'upper',
  logoFont = 'sans',
  href,
  hrefLabel,
} = Astro.props;

const fallbackText = name.slice(0, 3);
const text = logoText ?? (logoCase === 'upper' ? fallbackText.toUpperCase() : fallbackText.toLowerCase());
const background = logoGradient ?? logoColor;
---

<article class="logo-card">
  <div class="logo-card-header">
    <div
      class:list={["logo-tile", { mono: logoFont === 'mono' }]}
      style={`background: ${background};`}
    >
      {text}
    </div>
    <div class="logo-card-meta">
      <p class="logo-card-name">{name}</p>
      <p class="logo-card-subtitle">{subtitle}</p>
    </div>
  </div>
  <p class="logo-card-desc">{description}</p>
  {href && (
    <a href={href} target="_blank" rel="noopener" class="logo-card-link">
      {hrefLabel ?? href} →
    </a>
  )}
</article>

<style>
  .logo-card {
    border: 1px solid var(--gray-100);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
  }
  .logo-card-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }
  .logo-tile {
    width: 40px;
    height: 40px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 700;
    font-size: 14px;
    flex-shrink: 0;
  }
  .logo-tile.mono {
    font-family: var(--font-mono);
  }
  .logo-card-meta { flex: 1; }
  .logo-card-name {
    font-size: 14px;
    font-weight: 700;
    color: var(--black);
    margin: 0;
  }
  .logo-card-subtitle {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--gray-500);
    margin: 0;
  }
  .logo-card-desc {
    font-size: 13px;
    color: var(--gray-700);
    line-height: 1.55;
    margin: 0 0 12px;
    flex: 1;
  }
  .logo-card-link {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--gray-500);
    text-decoration: none;
  }
  .logo-card-link:hover { color: var(--accent); }
</style>
