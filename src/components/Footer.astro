---
import { site } from '../config/site';
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <p class="brand-line">
        <strong>{site.name}</strong> — {site.fullName}
      </p>
      <p class="footer-affiliation">
        Hosted by the
        <a href={site.affiliation.instituteUrl} target="_blank" rel="noopener">
          {site.affiliation.institute}</a>,
        <a href={site.affiliation.universityUrl} target="_blank" rel="noopener">
          {site.affiliation.university}</a>.
      </p>
    </div>
    <div class="footer-contact">
      <p class="footer-label">Contact</p>
      <p class="contact-line">
        <a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a>
      </p>
    </div>
    <div class="footer-right">
      <div class="footer-social">
        <a href={site.social.bluesky.profileUrl} target="_blank" rel="noopener me" aria-label="Follow on Bluesky">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.335 5.068C9.269 7.264 12.428 11.716 12 12.14c-.428-.424-3.587-4.876-6.521-7.072C3.787 3.78 2 5.087 2 7.44c0 2.352.17 3.918 1.51 4.988 1.342 1.07 4.27 1.62 5.677 1.36-2.413.446-4.541 1.56-2.192 4.167 2.35 2.606 4.135.65 5.005-1.336.87 1.986 2.656 3.942 5.005 1.336 2.349-2.607.221-3.721-2.192-4.166 1.407.258 4.335-.291 5.676-1.361C21.83 11.358 22 9.792 22 7.44c0-2.353-1.787-3.66-3.479-2.372C15.587 7.264 12.428 11.716 12 12.14"/>
          </svg>
        </a>
        <a href={site.social.mastodon.profileUrl} target="_blank" rel="noopener me" aria-label="Follow on Mastodon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M21.58 6.59c-.34-2.51-2.54-4.49-5.16-4.87C14.98 1.53 11.95 1 9.06 1H9c-2.89 0-3.91.53-4.35.71C2.11 2.1.32 3.95-.24 6.59.03 7.89.11 9.34.16 10.66c.07 1.9.08 3.8.26 5.69.12 1.26.33 2.51.64 3.74.57 2.27 2.83 4.17 5.05 4.94 2.37.8 4.93.94 7.37.39.27-.07.53-.14.79-.22.59-.19 1.28-.4 1.79-.77v-1.7s-.59.15-1.96.35c-1.1.13-2.22.16-3.32.08-1.73-.13-3.68-.48-4.11-2.52-.04-.19-.06-.38-.06-.58.54.12 1.09.21 1.64.29 1.86.26 3.74.3 5.61.13 1.06-.1 2.11-.28 3.15-.54 1.21-.3 2.49-.76 3.51-1.54C20.18 15.23 21 12.5 21 9.76c0-.52-.07-1.72-.08-2.25M17.5 15h-2.14V9.9c0-1.07-.45-1.61-1.36-1.61-1 0-1.51.65-1.51 1.94v2.81h-2.13v-2.81c0-1.29-.5-1.94-1.51-1.94-.91 0-1.36.54-1.36 1.61V15H5.36V9.74c0-1.07.27-1.92.82-2.55.57-.63 1.31-.95 2.23-.95 1.07 0 1.87.41 2.4 1.23l.53.89.53-.89c.53-.82 1.34-1.23 2.4-1.23.92 0 1.67.32 2.23.95.55.63.82 1.48.82 2.55V15Z"/>
          </svg>
        </a>
        <a href={site.social.x.profileUrl} target="_blank" rel="noopener me" aria-label="Follow on X">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      </div>
      <p class="copyright">&copy; {year} {site.name}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--gray-100);
    padding: var(--space-8) 0;
    margin-top: var(--space-16);
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-8);
    align-items: start;
  }
  .brand-line {
    font-size: 13px;
    color: var(--gray-700);
    margin-bottom: var(--space-1);
  }
  .footer-affiliation {
    font-size: 11px;
    color: var(--gray-500);
    line-height: 1.6;
  }
  .footer-affiliation a {
    color: var(--gray-500);
    text-decoration-color: var(--gray-300);
  }
  .footer-affiliation a:hover { color: var(--black); }

  .footer-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--gray-300);
    margin-bottom: var(--space-2);
  }
  .contact-line {
    font-size: 12px;
    color: var(--gray-700);
    margin: 0 0 3px 0;
  }
  .contact-line a {
    color: var(--gray-700);
    text-decoration: none;
  }
  .contact-line a:hover {
    text-decoration: underline;
    text-decoration-color: var(--accent);
  }

  .footer-right { text-align: right; }
  .footer-social {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
    margin-bottom: var(--space-3);
  }
  .footer-social a {
    color: var(--gray-500);
    display: inline-flex;
    transition: color 0.15s;
  }
  .footer-social a:hover { color: var(--accent); }
  .copyright {
    font-size: 11px;
    color: var(--gray-300);
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
    .footer-right { text-align: left; }
    .footer-social { justify-content: flex-start; }
  }
</style>
