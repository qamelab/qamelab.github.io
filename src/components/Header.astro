---
interface Props {
  active?: 'research' | 'papers' | 'software' | 'data' | 'team' | 'briefing';
}

const { active = 'research' } = Astro.props;

const navItems = [
  { key: 'research', label: 'Research', href: '/' },
  { key: 'papers',   label: 'Papers',   href: '/papers/' },
  { key: 'software', label: 'Software', href: '/software/' },
  { key: 'data',     label: 'Data',     href: '/data/' },
  { key: 'team',     label: 'Team',     href: '/team/' },
  { key: 'briefing', label: 'Briefing', href: '/briefing/' },
] as const;
---

<header class="site-header">
  <div class="container header-inner">
    <div class="header-left">
      <a href="/" class="logo-link" aria-label="QAME Lab — home">
        <span class="logo-row">
          <span class="logo-text">QAME</span>
          <span class="logo-suffix">Lab</span>
        </span>
        <span class="logo-rule" aria-hidden="true"></span>
      </a>
      <span class="header-divider"></span>
      <a
        href="https://www.bfh.ch/en/research/research-areas/institut-applied-data-science-and-finance/"
        class="affiliation"
        target="_blank"
        rel="noopener"
      >
        Hosted by the Institute for Applied Data Science &amp; Finance
        <span class="affiliation-org">Bern University of Applied Sciences</span>
      </a>
    </div>
    <nav class="header-nav">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={["nav-link", { active: active === item.key }]}
          aria-current={active === item.key ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
      <button
        id="theme-toggle"
        type="button"
        class="theme-toggle"
        aria-label="Toggle dark mode"
        title="Toggle dark mode"
      >
        <svg class="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
        </svg>
        <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('theme-toggle');
  if (btn) {
    btn.addEventListener('click', () => {
      const current = document.documentElement.dataset.theme;
      const next = current === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      try { localStorage.setItem('theme', next); } catch (_) {}
      btn.setAttribute('aria-label', `Switch to ${next === 'dark' ? 'light' : 'dark'} mode`);
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--surface-translucent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--gray-100);
  }

  .header-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 3.5rem;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .logo-link {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    text-decoration: none;
  }
  .logo-row {
    display: flex;
    align-items: baseline;
    gap: 4px;
  }
  .logo-text {
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -0.035em;
    color: var(--black);
  }
  .logo-suffix {
    font-size: 18px;
    font-weight: 300;
    color: var(--gray-300);
  }
  .logo-rule {
    display: block;
    width: 12px;
    height: 2px;
    background: var(--accent);
  }

  .header-divider {
    width: 1px;
    height: 20px;
    background: var(--gray-200);
  }

  .affiliation {
    font-size: 11px;
    line-height: 1.3;
    color: var(--gray-500);
    text-decoration: none;
    transition: color 0.15s;
  }
  .affiliation:hover { color: var(--gray-700); }
  .affiliation-org {
    display: block;
    color: var(--gray-300);
  }

  .header-nav {
    display: flex;
    gap: 22px;
    align-items: center;
  }

  .theme-toggle {
    background: none;
    border: none;
    padding: 4px;
    margin-left: 8px;
    cursor: pointer;
    color: var(--gray-500);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s;
  }
  .theme-toggle:hover { color: var(--black); }
  .theme-toggle .icon-sun  { display: none; }
  .theme-toggle .icon-moon { display: inline; }
  :global([data-theme="dark"]) .theme-toggle .icon-sun  { display: inline; }
  :global([data-theme="dark"]) .theme-toggle .icon-moon { display: none; }
  .nav-link {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    color: var(--gray-700);
    text-decoration: none;
    padding-bottom: 2px;
    transition: color 0.15s;
  }
  .nav-link:hover {
    color: var(--black);
  }
  .nav-link.active {
    color: var(--black);
    font-weight: 600;
    border-bottom: 2px solid var(--accent);
  }

  @media (max-width: 768px) {
    .affiliation { display: none; }
    .header-divider { display: none; }
    .header-nav { gap: 14px; }
  }
</style>
