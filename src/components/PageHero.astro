---
interface Props {
  label: string;
  title: string;
}

const { label, title } = Astro.props;
---

<div class="page-hero">
  <p class="label">{label}</p>
  <h1 class="page-h1">{title}</h1>
  <hr class="rule" />
  <slot />
</div>

<style>
  .page-h1 {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
</style>
