---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ResearchAreas from '../components/ResearchAreas.astro';
import ProjectsGrants from '../components/ProjectsGrants.astro';
import FeedSidebar from '../components/FeedSidebar.astro';
import { site } from '../config/site';
---

<Base title={site.name} description={site.description}>
  <Header active="research" />

  <section class="section hero-section">
    <div class="container hero-grid">
      <div class="hero-main">
        <p class="kicker">{site.fullName}</p>
        <h1 class="hero-title">QAME <span class="light">Lab</span></h1>
        <hr class="rule" />
        <p class="lead">
          We study how AI and media shape economic decisions and information
          flows — and what that means for politics, society, and the economy.
        </p>

        <div class="research-wrap">
          <ResearchAreas />
        </div>
      </div>
      <aside class="hero-side">
        <FeedSidebar />
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <ProjectsGrants />
    </div>
  </section>

  <Footer />
</Base>

<style>
  .hero-section {
    padding-top: var(--space-14);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-12);
    align-items: start;
  }
  .hero-main {
    max-width: 40rem;
  }
  .kicker {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--accent-deep);
    margin-bottom: 12px;
  }
  .hero-title {
    font-size: 52px;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-bottom: 0;
  }
  .hero-title .light {
    font-weight: 300;
    color: var(--gray-500);
  }
  .lead {
    font-size: 17px;
    color: var(--gray-700);
    line-height: var(--leading-relaxed);
    margin-top: var(--space-4);
    margin-bottom: var(--space-10);
  }

  .research-wrap {
    margin-top: var(--space-8);
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
    .hero-title { font-size: 44px; }
  }
  @media (max-width: 640px) {
    .hero-title { font-size: 36px; }
  }
</style>
