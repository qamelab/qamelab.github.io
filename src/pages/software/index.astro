---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';
import LogoCard from '../../components/LogoCard.astro';
import { getCollection } from 'astro:content';

const software = (await getCollection('software'))
  .sort((a, b) => a.data.order - b.data.order);

function extractHost(url: string): string {
  try {
    const u = new URL(url);
    return u.host + u.pathname.replace(/\/$/, '');
  } catch {
    return url;
  }
}
---

<Base title="Software">
  <Header active="software" />

  <section class="section">
    <div class="container">
      <PageHero label="Software" title="Tools & open-source infrastructure">
        <p class="page-intro">
          Open-source tools, libraries, and agentic infrastructure developed at
          QAME Lab. All projects are public on GitHub and designed for
          reproducible, local-first research.
        </p>
      </PageHero>

      {software.length > 0 ? (
        <div class="card-grid">
          {software.map(item => (
            <LogoCard
              name={item.data.fullName ?? item.data.name}
              subtitle={item.data.stack}
              description={item.data.description}
              logoColor={item.data.logoColor}
              logoGradient={item.data.logoGradient}
              logoText={item.data.logoText}
              logoCase="lower"
              logoFont="mono"
              href={item.data.repo}
              hrefLabel={extractHost(item.data.repo)}
            />
          ))}
        </div>
      ) : (
        <p class="empty-note">Projects will be listed here as they become public.</p>
      )}
    </div>
  </section>

  <Footer />
</Base>

<style>
  .card-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  @media (max-width: 768px) {
    .card-grid { grid-template-columns: 1fr; }
  }
</style>
