---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';
import LogoCard from '../../components/LogoCard.astro';
import { getCollection } from 'astro:content';

const datasets = (await getCollection('data'))
  .sort((a, b) => a.data.order - b.data.order);
---

<Base title="Data">
  <Header active="data" />

  <section class="section">
    <div class="container">
      <PageHero label="Data" title="Datasets & research resources">
        <p class="page-intro">
          Curated datasets, annotated corpora, and derived resources from
          QAME Lab research. All datasets are archived on Zenodo with a persistent
          DOI and released under open licenses where legally possible.
        </p>
      </PageHero>

      {datasets.length > 0 ? (
        <div class="card-grid">
          {datasets.map(item => {
            const doiHref = item.data.doi ? `https://doi.org/${item.data.doi}` : undefined;
            const href = doiHref ?? item.data.url;
            const hrefLabel = item.data.doi ? `doi.org/${item.data.doi}` : href ? 'Details' : undefined;
            return (
              <LogoCard
                name={item.data.name}
                subtitle={item.data.format}
                description={item.data.description}
                logoColor={item.data.logoColor}
                logoText={item.data.logoText}
                logoCase="upper"
                href={href}
                hrefLabel={hrefLabel}
              />
            );
          })}
        </div>
      ) : (
        <p class="empty-note">Datasets will be listed here once they have persistent DOIs.</p>
      )}
    </div>
  </section>

  <Footer />
</Base>

<style>
  .card-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  @media (max-width: 768px) {
    .card-grid { grid-template-columns: 1fr; }
  }
</style>
